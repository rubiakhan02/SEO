{
  "manifest_version": 3,
  "name": "Company SEO Rank Checker",
  "description": "Scrapes Google results from the employee browser session for internal rank checks.",
  "version": "1.0.0",
  "incognito": "spanning",
  "permissions": ["tabs", "windows", "scripting"],
  "host_permissions": [
    "https://www.google.com/*",
    "https://www.google.co.in/*",
    "http://localhost:3000/*",
    "https://*.vercel.app/*",
    "https://seo-54kh.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Company SEO Rank Checker",
    "default_popup": "popup.html"
  },
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "https://*.vercel.app/*",
      "https://seo-54kh.onrender.com/*"
    ]
  }
}